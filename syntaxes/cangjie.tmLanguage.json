{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/tc39-proposal-scope-mapping/refs/heads/main/vscode/tmlanguage.schema.json",
  "name": "Cangjie",
  "scopeName": "source.cangjie",
  "patterns": [
    { "include": "#comments" },
    { "include": "#annotations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#variables" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cangjie",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cangjie",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            { "include": "#comments" }
          ]
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "name": "meta.annotation.cangjie",
          "match": "@([A-Za-z_]\\w*)",
          "captures": {
            "0": { "name": "entity.name.function.decorator.cangjie" }
          }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cangjie",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cangjie",
              "match": "\\\\."
            },
            {
              "name": "meta.interpolation.cangjie",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": { "name": "punctuation.definition.interpolation.begin.cangjie" }
              },
              "end": "\\}",
              "endCaptures": {
                "0": { "name": "punctuation.definition.interpolation.end.cangjie" }
              },
              "patterns": [
                { "include": "$self" }
              ]
            }
          ]
        },
        {
          "name": "string.quoted.single.cangjie",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cangjie",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.triple.cangjie",
          "begin": "\"\"\"",
          "end": "\"\"\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.cangjie",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "name": "constant.numeric.binary.cangjie",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "name": "constant.numeric.octal.cangjie",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "name": "constant.numeric.float.cangjie",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.cangjie",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cangjie",
          "match": "\\b(if|else|match|case|for|while|do|break|continue|return|try|catch|throw|finally|in|is|where|from)\\b"
        },
        {
          "name": "keyword.declaration.cangjie",
          "match": "\\b(let|var|func|class|struct|enum|interface|extend|type|package|import|operator|prop|macro|main|init)\\b"
        },
        {
          "name": "keyword.modifier.cangjie",
          "match": "\\b(public|private|protected|internal|open|abstract|override|sealed|static|mut|const|foreign|unsafe|redef|inout|synchronized|spawn|super|this|quote)\\b"
        },
        {
          "name": "keyword.other.cangjie",
          "match": "\\b(as|get|set)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.cangjie",
          "match": "\\b(Bool|Int8|Int16|Int32|Int64|IntNative|UInt8|UInt16|UInt32|UInt64|UIntNative|Float16|Float32|Float64|Rune|Nothing|Unit|VArray|This|String|Array|HashMap|HashSet|ArrayList|Option|Result)\\b"
        },
        {
          "name": "entity.name.type.cangjie",
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.cangjie",
          "match": "\\b(true|false|None)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.cangjie",
          "match": "(=>|->|\\|>|\\.\\.)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "meta.function.cangjie",
          "match": "\\b(func)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.cangjie" },
            "2": { "name": "entity.name.function.cangjie" }
          }
        },
        {
          "name": "meta.function-call.cangjie",
          "match": "\\b([a-z_]\\w*)\\s*\\(",
          "captures": {
            "1": { "name": "entity.name.function.cangjie" }
          }
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "meta.variable.cangjie",
          "match": "\\b(let|var)\\s+([a-zA-Z_]\\w*)",
          "captures": {
            "1": { "name": "keyword.declaration.cangjie" },
            "2": { "name": "variable.other.cangjie" }
          }
        }
      ]
    }
  }
}
