{
  "name": "harmony-dev-tools",
  "displayName": "HarmonyOS Dev Tools",
  "description": "Build, run, debug, inspect, and validate HarmonyOS apps directly in VS Code",
  "version": "0.6.14",
  "publisher": "corn12138",
  "license": "MIT",
  "icon": "resources/icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/corn12138/harmony-dev-tools"
  },
  "homepage": "https://github.com/corn12138/harmony-dev-tools#readme",
  "bugs": {
    "url": "https://github.com/corn12138/harmony-dev-tools/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Debuggers"
  ],
  "keywords": [
    "HarmonyOS",
    "HarmonyOS NEXT",
    "ArkTS",
    "ArkUI",
    "OpenHarmony",
    "鸿蒙",
    "ets",
    "Cangjie",
    "仓颉"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/build-profile.json5"
  ],
  "contributes": {
    "languages": [
      {
        "id": "arkts",
        "aliases": [
          "ArkTS",
          "arkts",
          "ETS"
        ],
        "extensions": [
          ".ets"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/arkts-light.svg",
          "dark": "./resources/icons/arkts-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "arkts",
        "scopeName": "source.arkts",
        "path": "./syntaxes/arkts.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.typescript": "typescript"
        }
      }
    ],
    "snippets": [
      {
        "language": "arkts",
        "path": "./snippets/arkts.snippets.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "**/build-profile.json5",
        "url": "./schemas/build-profile.schema.json"
      },
      {
        "fileMatch": "**/oh-package.json5",
        "url": "./schemas/oh-package.schema.json"
      },
      {
        "fileMatch": "**/module.json5",
        "url": "./schemas/module.schema.json"
      },
      {
        "fileMatch": "**/AppScope/app.json5",
        "url": "./schemas/app.schema.json"
      },
      {
        "fileMatch": "**/hvigor/hvigor-config.json5",
        "url": "./schemas/hvigor-config.schema.json"
      }
    ],
    "commands": [
      {
        "command": "harmony.createProject",
        "title": "Create HarmonyOS Project",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.openControlCenter",
        "title": "Open HarmonyOS Control Center",
        "category": "HarmonyOS",
        "icon": "$(rocket)"
      },
      {
        "command": "harmony.buildHap",
        "title": "Build HAP Package",
        "category": "HarmonyOS",
        "icon": "$(play)"
      },
      {
        "command": "harmony.runOnDevice",
        "title": "Run Built App on Device",
        "category": "HarmonyOS",
        "icon": "$(debug-start)"
      },
      {
        "command": "harmony.clean",
        "title": "Clean Build",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.viewDevices",
        "title": "Refresh Device List",
        "category": "HarmonyOS",
        "icon": "$(refresh)"
      },
      {
        "command": "harmony.selectDevice",
        "title": "Select Active Device",
        "category": "HarmonyOS",
        "icon": "$(device-mobile)"
      },
      {
        "command": "harmony.useDevice",
        "title": "Use This Device",
        "category": "HarmonyOS",
        "icon": "$(device-mobile)"
      },
      {
        "command": "harmony.installHap",
        "title": "Install HAP to Device",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.viewLogs",
        "title": "Open Device Logs (hilog)",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.openWebViewDevTools",
        "title": "Open WebView DevTools",
        "category": "HarmonyOS",
        "icon": "$(globe)"
      },
      {
        "command": "harmony.previewComponent",
        "title": "Preview ArkUI Component",
        "category": "HarmonyOS",
        "icon": "$(open-preview)"
      },
      {
        "command": "harmony.formatDocument",
        "title": "Format ArkTS File",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.organizeImports",
        "title": "Organize Imports",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.extractComponent",
        "title": "Extract to @Component",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.extractBuilder",
        "title": "Extract to @Builder",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.extractString",
        "title": "Extract to $r() Resource",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.manageDeps",
        "title": "Manage OHPM Dependencies",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.openDocs",
        "title": "Open HarmonyOS Docs Search",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.uiInspector",
        "title": "Inspect Running UI",
        "category": "HarmonyOS",
        "icon": "$(inspect)"
      },
      {
        "command": "harmony.takeScreenshot",
        "title": "Capture Device Screenshot",
        "category": "HarmonyOS",
        "icon": "$(device-camera)"
      },
      {
        "command": "harmony.buildAndRun",
        "title": "One-Click Build, Install & Run",
        "category": "HarmonyOS",
        "icon": "$(rocket)"
      },
      {
        "command": "harmony.terminalBuildAndRun",
        "title": "Build, Install & Run in Terminal",
        "category": "HarmonyOS",
        "icon": "$(terminal)"
      },
      {
        "command": "harmony.stopApp",
        "title": "Stop Running App on Device",
        "category": "HarmonyOS",
        "icon": "$(debug-stop)"
      },
      {
        "command": "harmony.debugApp",
        "title": "Debug App on Device",
        "category": "HarmonyOS",
        "icon": "$(debug-alt)"
      },
      {
        "command": "harmony.migrateV1ToV2",
        "title": "Migrate V1 → V2 Decorators",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.migrateBuildProfile",
        "title": "Upgrade Legacy build-profile",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.checkApiCompat",
        "title": "Check API / SDK Compatibility",
        "category": "HarmonyOS"
      },
      {
        "command": "harmony.openDeviceMirror",
        "title": "Open Device Mirror",
        "category": "HarmonyOS",
        "icon": "$(device-mobile)"
      },
      {
        "command": "harmony.launchEmulator",
        "title": "Start Emulator",
        "category": "HarmonyOS",
        "icon": "$(vm)"
      },
      {
        "command": "harmony.stopEmulator",
        "title": "Stop Emulator",
        "category": "HarmonyOS",
        "icon": "$(debug-stop)"
      },
      {
        "command": "harmony.checkEnvironment",
        "title": "Check SDK / HDC Environment",
        "category": "HarmonyOS",
        "icon": "$(checklist)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "harmony-explorer",
          "title": "HarmonyOS",
          "icon": "resources/icons/harmony.svg"
        }
      ]
    },
    "views": {
      "harmony-explorer": [
        {
          "id": "harmony.quickActionsView",
          "name": "Quick Actions",
          "when": "harmony.isHarmonyProject"
        },
        {
          "id": "harmony.projectView",
          "name": "Project Files",
          "when": "harmony.isHarmonyProject"
        },
        {
          "id": "harmony.deviceView",
          "name": "Connected Devices",
          "when": "harmony.isHarmonyProject"
        },
        {
          "id": "harmony.resourceView",
          "name": "App Resources",
          "when": "harmony.isHarmonyProject"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "harmony.extractComponent",
          "when": "editorLangId == arkts",
          "group": "1_modification"
        },
        {
          "command": "harmony.extractBuilder",
          "when": "editorLangId == arkts",
          "group": "1_modification"
        },
        {
          "command": "harmony.extractString",
          "when": "editorLangId == arkts",
          "group": "1_modification"
        },
        {
          "command": "harmony.previewComponent",
          "when": "editorLangId == arkts",
          "group": "navigation"
        },
        {
          "command": "harmony.migrateV1ToV2",
          "when": "editorLangId == arkts",
          "group": "1_modification"
        },
        {
          "command": "harmony.migrateBuildProfile",
          "when": "resourceFilename == build-profile.json5",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "harmony.buildHap",
          "when": "harmony.isHarmonyProject",
          "group": "navigation"
        },
        {
          "command": "harmony.runOnDevice",
          "when": "harmony.isHarmonyProject",
          "group": "navigation"
        },
        {
          "command": "harmony.buildAndRun",
          "when": "harmony.isHarmonyProject",
          "group": "navigation"
        },
        {
          "command": "harmony.openDeviceMirror",
          "when": "harmony.isHarmonyProject",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "harmony.openControlCenter",
          "when": "view == harmony.quickActionsView",
          "group": "navigation"
        },
        {
          "command": "harmony.viewDevices",
          "when": "view == harmony.deviceView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "harmony.useDevice",
          "when": "view == harmony.deviceView && (viewItem == device-online || viewItem == emulator-running)",
          "group": "inline"
        },
        {
          "command": "harmony.openDeviceMirror",
          "when": "view == harmony.deviceView && (viewItem == device-online || viewItem == emulator-running)",
          "group": "navigation"
        },
        {
          "command": "harmony.uiInspector",
          "when": "view == harmony.deviceView && (viewItem == device-online || viewItem == emulator-running)",
          "group": "navigation"
        },
        {
          "command": "harmony.viewLogs",
          "when": "view == harmony.deviceView && (viewItem == device-online || viewItem == emulator-running)",
          "group": "navigation"
        },
        {
          "command": "harmony.openWebViewDevTools",
          "when": "view == harmony.deviceView && (viewItem == device-online || viewItem == emulator-running)",
          "group": "navigation"
        },
        {
          "command": "harmony.takeScreenshot",
          "when": "view == harmony.deviceView && (viewItem == device-online || viewItem == emulator-running)",
          "group": "navigation"
        },
        {
          "command": "harmony.launchEmulator",
          "when": "view == harmony.deviceView && viewItem == emulator-stopped",
          "group": "inline"
        },
        {
          "command": "harmony.stopEmulator",
          "when": "view == harmony.deviceView && viewItem == emulator-running",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "HarmonyOS Dev Tools",
      "properties": {
        "harmony.sdkPath": {
          "type": "string",
          "default": "",
          "description": "Path to HarmonyOS/OpenHarmony SDK root directory"
        },
        "harmony.hdcPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the HDC executable. Leave empty to auto-detect."
        },
        "harmony.autoFormatOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Auto format ArkTS files on save"
        },
        "harmony.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show component references and route info as CodeLens"
        },
        "harmony.enableResourceValidation": {
          "type": "boolean",
          "default": true,
          "description": "Validate $r() resource references"
        },
        "harmony.logLevel": {
          "type": "string",
          "enum": [
            "debug",
            "info",
            "warn",
            "error"
          ],
          "default": "info",
          "description": "Extension log level"
        },
        "harmony.devicePollInterval": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "Refresh interval for the device list and active-device status bar, in milliseconds"
        },
        "harmony.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time ArkTS diagnostics for type issues, state traps, and common performance anti-patterns"
        },
        "harmony.enableProjectConfigDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Validate build-profile migration, startup page wiring, main_pages.json, routerMap, and Navigation route names"
        },
        "harmony.enablePerfLens": {
          "type": "boolean",
          "default": true,
          "description": "Show performance insight CodeLens on build(), ForEach, and component state usage"
        },
        "harmony.enableOhpmInsight": {
          "type": "boolean",
          "default": true,
          "description": "Show OHPM dependency insights, latest-version hints, and outdated package warnings"
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "hvigor",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "The hvigor task to run"
          },
          "module": {
            "type": "string",
            "description": "Target module name"
          }
        }
      }
    ],
    "debuggers": [
      {
        "type": "harmonyos",
        "label": "HarmonyOS Debug",
        "languages": [
          "arkts"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [],
            "properties": {
              "bundleName": {
                "type": "string",
                "description": "App bundle name (auto-detected from app.json5 if empty)",
                "default": ""
              },
              "abilityName": {
                "type": "string",
                "description": "Entry ability name",
                "default": "EntryAbility"
              },
              "deviceId": {
                "type": "string",
                "description": "Target device ID (auto-selected if empty)",
                "default": ""
              },
              "debugPort": {
                "type": "number",
                "description": "Debug port for CDP connection",
                "default": 9230
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "HarmonyOS: Debug App",
            "description": "Launch and debug a HarmonyOS application",
            "body": {
              "type": "harmonyos",
              "request": "launch",
              "name": "Debug HarmonyOS App",
              "bundleName": "",
              "abilityName": "EntryAbility",
              "debugPort": 9230
            }
          }
        ]
      }
    ],
    "problemMatchers": [
      {
        "name": "hvigor",
        "owner": "arkts",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(error|warning):\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outdir=dist --external:vscode --format=cjs --platform=node --target=es2022 --sourcemap",
    "build:prod": "pnpm build --minify --tree-shaking=true",
    "watch": "pnpm build --watch",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "size-check": "node scripts/size-check.js"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0",
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.18.0+sha512.e804f889f1cecc40d572db084eec3e4881739f8dec69c0ff10d2d1beff9a4e309383ba27b5b750059d7f4c149535b6cd0d2cb1ed3aeb739239a4284a68f40cfa"
}
