{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HarmonyOS Build Profile",
  "description": "HarmonyOS 构建配置文件 / Build configuration file (supports legacy compileSdkVersion and modern targetSdkVersion projects)",
  "type": "object",
  "properties": {
    "app": {
      "type": "object",
      "description": "应用级构建配置 / Application-level build configuration",
      "properties": {
        "signingConfigs": {
          "type": "array",
          "description": "签名配置列表 / Signing configurations",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "签名配置名称 / Signing config name" },
              "type": { "type": "string", "enum": ["HarmonyOS", "OpenHarmony"], "description": "签名类型" },
              "material": {
                "type": "object",
                "properties": {
                  "certpath": { "type": "string" },
                  "storeFile": { "type": "string" },
                  "signAlg": { "type": "string" },
                  "profile": { "type": "string" },
                  "keyAlias": { "type": "string", "description": "密钥别名 / Key alias" },
                  "storePassword": { "type": "string" },
                  "keyPassword": { "type": "string" }
                }
              }
            }
          }
        },
        "products": {
          "type": "array",
          "description": "产品配置列表 / Product configurations",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "产品名称 (default/free/paid)" },
              "signingConfig": { "type": "string" },
              "compatibleSdkVersion": { "type": ["string", "number"], "description": "最低兼容 SDK 版本 (e.g., 14 or '5.0.5(17)')" },
              "targetSdkVersion": { "type": ["string", "number"], "description": "目标 SDK 版本 (e.g., '6.0.0(20)' or '6.0.2(22)')" },
              "compileSdkVersion": { "type": ["string", "number"], "description": "旧版编译 SDK 版本 (legacy, e.g., 14)" },
              "runtimeOS": { "type": "string", "enum": ["HarmonyOS", "OpenHarmony"] },
              "bundleName": { "type": "string", "description": "应用包名 / Bundle name (API 13+)" },
              "buildOption": {
                "type": "object",
                "description": "构建选项 / Build options",
                "properties": {
                  "strictMode": {
                    "type": "object",
                    "properties": {
                      "caseSensitiveCheck": { "type": "boolean", "description": "大小写敏感检查" },
                      "useNormalizedOHMUrl": { "type": "boolean", "description": "使用标准化 OHM URL (API 14+)" }
                    }
                  }
                }
              }
            },
            "required": ["name"]
          }
        }
        ,
        "buildModeSet": {
          "type": "array",
          "description": "构建模式集合 / Build mode set",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "构建模式名称 (e.g., debug/release)" }
            },
            "required": ["name"]
          }
        }
      }
    },
    "modules": {
      "type": "array",
      "description": "模块配置列表 / Module configurations",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "模块名称 / Module name" },
          "srcPath": {
            "type": ["string", "array"],
            "description": "源码路径（API 14+ 支持数组形式跨项目引用）/ Source path (array supported in API 14+)",
            "items": { "type": "string" }
          },
          "targets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "applyToProducts": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "required": ["name", "srcPath"]
      }
    }
  }
}
